+/// Deterministic hashed ownership of determinants across MPI ranks.
+#[derive(Clone)]
+pub(crate) struct Ownership {
+    /// Owning MPI rank for each determinant.
+    pub(crate) ownerof: Vec<usize>,
+    /// Global determinant index for each rank-local determinant.
+    pub(crate) local2global: Vec<usize>,
+    /// Rank-local index for each global determinant, or `usize::MAX` if not owned locally.
+    pub(crate) global2local: Vec<usize>,
+}
+
+impl Ownership {
+    /// Construct hashed determinant ownership and local indexing.
+    /// # Arguments:
+    /// - `irank`: Current MPI rank.
+    /// - `ndets`: Number of determinants.
+    /// - `nranks`: Number of MPI ranks.
+    /// # Returns
+    /// - `Ownership`: Hashed ownership and rank-local index maps.
+    pub(in crate::stochastic) fn new(irank: usize, ndets: usize, nranks: usize) -> Self {
+        let mut ownerof = vec![0; ndets];
+        let mut local2global = Vec::new();
+        let mut global2local = vec![usize::MAX; ndets];
+
+        for det in 0..ndets {
+            let rank = hash_owner(det, nranks);
+            ownerof[det] = rank;
+            if rank == irank {
+                global2local[det] = local2global.len();
+                local2global.push(det);
+            }
+        }
+
+        Self {ownerof, local2global, global2local}
+    }
+
+    /// Return owning rank for a determinant.
+    /// # Arguments:
+    /// - `det`: Global determinant index.
+    /// # Returns
+    /// - `usize`: MPI rank that owns the determinant.
+    #[inline(always)]
+    pub(crate) fn owner(&self, det: usize) -> usize {
+        self.ownerof[det]
+    }
+
+    /// Return rank-local index for a determinant if it is owned locally.
+    /// # Arguments:
+    /// - `det`: Global determinant index.
+    /// # Returns
+    /// - `Option<usize>`: Rank-local index if owned on this rank.
+    #[inline(always)]
+    pub(crate) fn localidx(&self, det: usize) -> Option<usize> {
+        let ilocal = self.global2local[det];
+        if ilocal == usize::MAX {None} else {Some(ilocal)}
+    }
+
+    /// Return global determinant index for a rank-local determinant.
+    /// # Arguments:
+    /// - `ilocal`: Rank-local determinant index.
+    /// # Returns
+    /// - `usize`: Global determinant index.
+    #[inline(always)]
+    pub(crate) fn globalidx(&self, ilocal: usize) -> usize {
+        self.local2global[ilocal]
+    }
+
+    /// Return number of determinants owned locally.
+    /// # Returns
+    /// - `usize`: Number of rank-local determinants.
+    #[inline(always)]
+    pub(crate) fn nlocal(&self) -> usize {
+        self.local2global.len()
+    }
+}
+
+/// Deterministic owner for a determinant under hashed ownership.
+/// # Arguments:
+/// - `det`: Global determinant index.
+/// - `nranks`: Number of MPI ranks.
+/// # Returns
+/// - `usize`: Owning MPI rank.
+#[inline(always)]
+fn hash_owner(det: usize, nranks: usize) -> usize {
+    (splitmix64(det as u64) as usize) % nranks
+}
+
+/// SplitMix64 mixer used to deterministically hash determinant indices.
+/// # Arguments:
+/// - `x`: Input integer.
+/// # Returns
+/// - `u64`: Mixed integer.
+#[inline(always)]
+fn splitmix64(mut x: u64) -> u64 {
+    x = x.wrapping_add(0x9e3779b97f4a7c15);
+    x = (x ^ (x >> 30)).wrapping_mul(0xbf58476d1ce4e5b9);
+    x = (x ^ (x >> 27)).wrapping_mul(0x94d049bb133111eb);
+    x ^ (x >> 31)
+}
